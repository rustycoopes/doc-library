DATABASE_URL=postgresql://user:password@host:5432/dbname
# Same signing key as the Host's JWT_SECRET (organize-me repo) - Doc Library only verifies,
# never issues, so this must match exactly in every shared environment.
JWT_SECRET=change-me-to-the-same-value-as-the-hosts-jwt-secret

# No ENCRYPTION_KEY here, deliberately - Doc Library stores no third-party credentials (no OAuth
# tokens, no storage-provider connections), so there's nothing for a Fernet key to encrypt. Don't
# cargo-cult it in from event-creator's .env.local.example.
